#--------------------------------------------------------------------
# MAIL CONFIGURATION
#--------------------------------------------------------------------
mail.fromEmail=admin@novamiinfotechs.com
mail.fromName="Medzus Healthcare Pvt. Ltd."
mail.protocol=smtp
mail.SMTPHost=relay-hosting.secureserver.net
mail.SMTPAuth=false
mail.SMTPPort=25
mail.SMTPCrypto=none
mail.SMTPUser=admin@novamiinfotechs.com
mail.SMTPPass="admin@novamiinfotechs.com"
# mail.SMTPPort=587
mail.SMTPTimeout=30
mail.SMTPKeepAlive=true
# mail.SMTPCrypto=ssl
mail.mailType=html
mail.charset=utf-8
mail.wordWrap=true

#--------------------------------------------------------------------
# Admin MAil CONFIGURATION
#--------------------------------------------------------------------
ADMIN_EMAIL=jr.developer.novami@gmail.com